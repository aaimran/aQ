! waveqlab3d input file: anelastic-Q validation test
! Constant-Q half-space (Q_S = 50, Q_P = 100)
! N=4 GSLS mechanisms, corrected tau spacing (denominator = 2*N)
! NNLS-fitted weights for gamma=0, band [0.05, 20] Hz

&problem_list
 name = 'data/anelastic_Q_test',
 problem = 'TPV5',
 response = 'anelastic-Q',
 nblocks = 2,
 t_final = 8d0,
 CFL = 0.5d0,
 coupling = 'locked',
 type_of_mesh = 'curvilinear',
 material_source = 'hard-coded',
 interpol = F,
 use_topography = F,
 mollify_source = F,
 w_stride = 2,
 w_fault = F /

! anelastic-Q parameters:
!   c    : Q_S = c * V_S  (Q_P = 2 * Q_S, hard-coded ratio)
!          c = Q_S / V_S = 50 / 3.464 km/s ~ 14.433
!   fref : reference frequency for unrelaxed modulus correction (Hz)
!
! Resulting Q_S ~ 50 at V_S = 3.464 km/s (rho_s_p(2) parameter)
! Resulting Q_P ~ 100

&anelastic_Q_list
 c    = 14.4328d0,
 fref = 1.0d0 /

&block_list
btp(1)%nqrs = 101, 101, 201,
btp(1)%aqrs = -10d0, 0d0, -10d0,
btp(1)%bqrs =   0d0, 10d0, 10d0,
btp(1)%rho_s_p = 2.7d0, 3.464d0, 6d0,
btp(1)%lqrs = 1, 1, 1,
btp(1)%rqrs = 0, 1, 1,
btp(1)%pml_lqrs = T, F, T,
btp(1)%pml_rqrs = F, T, T,
btp(1)%npml = 12,
btp(1)%lc = 1d0,
btp(1)%rc = 0d0,
btp(1)%profile_type = 'no_path',
btp(1)%topography_type = 'flat',

btp(2)%nqrs = 101, 101, 201,
btp(2)%aqrs =   0d0, 0d0, -10d0,
btp(2)%bqrs =  10d0, 10d0, 10d0,
btp(2)%rho_s_p = 2.7d0, 3.464d0, 6d0,
btp(2)%lqrs = 0, 1, 1,
btp(2)%rqrs = 1, 1, 1,
btp(2)%pml_lqrs = F, F, T,
btp(2)%pml_rqrs = T, T, T,
btp(2)%npml = 12,
btp(2)%lc = 0d0,
btp(2)%rc = 1d0,
btp(2)%profile_type = 'no_path',
btp(2)%topography_type = 'flat' /

&moment_list
 use_moment_tensor = T,
 order = 4 /

! source_type  duration  t_init  mXX  mYY  mZZ  mXY  mXZ  mYZ  x  y  z  alpha
! Isotropic explosion at (0, 5, 0) km

!---begin:tensor_listU---
'gaussian' 0.5d0 0.0d0 1d0 1d0 1d0 0d0 0d0 0d0 0d0 5d0 0d0 0
!---end:tensor_listU---

!---begin:tensor_listV---
'gaussian' 0.5d0 0.0d0 1d0 1d0 1d0 0d0 0d0 0d0 0d0 5d0 0d0 0
!---end:tensor_listV---

&mms_list
 use_mms = F /

&output_list
 output_exact_moment = F,
 output_seismograms = T,
 output_fault_topo = F,
 output_fields_block1 = F,
 output_fields_block2 = F,
 stride_fields = 1,
 station_xyz_index = T /

! Receivers at 5 km offsets on the free surface (y=10 km)
!---begin:station_listU---
 0d0 10d0  0d0
 5d0 10d0  0d0
-5d0 10d0  0d0
 0d0 10d0  5d0
 0d0 10d0 -5d0
!---end:station_listU---

!---begin:station_listV---
 0d0 10d0  0d0
 5d0 10d0  0d0
-5d0 10d0  0d0
 0d0 10d0  5d0
 0d0 10d0 -5d0
!---end:station_listV---
